# Git LFS — arquivos binários grandes rastreados via LFS
# (evita warnings de arquivo >50MB e mantém o repositório leve)

# Modelos PyTorch
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text

# DLLs do Tesseract portable
tools/tesseract-portable/*.dll filter=lfs diff=lfs merge=lfs -text
tools/tesseract-portable/tesseract.exe filter=lfs diff=lfs merge=lfs -text

# Modelos de linguagem Tesseract
tools/tesseract-portable/tessdata/*.traineddata filter=lfs diff=lfs merge=lfs -text

# Imagens de teste grandes
test-assets/*.jpg filter=lfs diff=lfs merge=lfs -text
test-assets/*.png filter=lfs diff=lfs merge=lfs -text
test-assets/*.jpeg filter=lfs diff=lfs merge=lfs -text
